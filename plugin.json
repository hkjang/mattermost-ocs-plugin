{
    "id": "com.mattermost.ocs-plugin",
    "name": "OpenCode",
    "version": "0.1.32",
    "description": "Mattermost bots backed by OpenCode sessions, agent defaults, and streaming replies.",
    "homepage_url": "https://github.com/hkjang/mattermost-ocs-plugin",
    "support_url": "https://github.com/hkjang/mattermost-ocs-plugin/issues",
    "icon_path": "assets/ocs-plugin-icon.svg",
    "min_server_version": "10.0.0",
    "server": {
        "executables": {
            "linux-amd64": "server/dist/plugin-linux-amd64",
            "linux-arm64": "server/dist/plugin-linux-arm64",
            "darwin-amd64": "server/dist/plugin-darwin-amd64",
            "darwin-arm64": "server/dist/plugin-darwin-arm64",
            "windows-amd64": "server/dist/plugin-windows-amd64.exe"
        }
    },
    "webapp": {
        "bundle_path": "webapp/dist/main.js"
    },
    "settings_schema": {
        "header": "",
        "footer": "",
        "settings": [
            {
                "key": "Config",
                "type": "custom"
            }
        ]
    }
}
